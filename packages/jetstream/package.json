{
  "name": "@pimmesz/jetstream",
  "version": "0.0.0",
  "private": true,
  "description": "Full Claude control on your Elgato Stream Deck.",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "node scripts/build.mjs",
    "check": "pnpm typecheck && pnpm test",
    "pack": "streamdeck pack gg.pim.jetstream.sdPlugin",
    "link": "streamdeck link gg.pim.jetstream.sdPlugin",
    "validate": "streamdeck validate gg.pim.jetstream.sdPlugin"
  },
  "dependencies": {
    "@elgato/streamdeck": "^2.1.0",
    "@pimmesz/jetstream-claude": "workspace:*",
    "@pimmesz/jetstream-status": "workspace:*",
    "@pimmesz/jetstream-usage": "workspace:*"
  },
  "devDependencies": {
    "@elgato/cli": "^1.7.4",
    "@types/node": "^25.9.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "esbuild": "^0.25.0"
  }
}
