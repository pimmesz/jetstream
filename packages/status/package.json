{
  "name": "@pimmesz/jetstream-status",
  "version": "0.0.0",
  "private": true,
  "description": "Per-project Claude Code status (from lifecycle hooks) for the Jetstream Stream Deck board.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "jetstream-status-hook": "./dist/hook.js",
    "jetstream-permission-hook": "./dist/permission-hook.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsup src/index.ts src/hook.ts src/permission-hook.ts --format esm --dts --clean",
    "check": "pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
